# Guard Configuration Example

# LM Studio or OpenAI-compatible endpoint
GUARD_BASE_URL=http://127.0.0.1:1234/v1
GUARD_API_KEY=lm-studio
GUARD_MODEL=gemma-4-e4b-it-mxfp8

# Security boundaries
GUARD_SANDBOX_DIR=./sandbox
GUARD_REPO_ROOT=.

# Operational settings
GUARD_POLL_INTERVAL_SEC=5
GUARD_MAX_ITERATIONS=10
GUARD_MAX_MEMORY_CHARS=10000
GUARD_COMMAND_TIMEOUT_SEC=30

# Logs
GUARD_AUDIT_LOG=state/guard-audit.jsonl
GUARD_MEMORY_LOG=state/guard-state.md
