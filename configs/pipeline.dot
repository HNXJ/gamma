digraph Pipeline {
    rankdir=LR;
    fontname="Arial";
    node [fontname="Arial", shape=box, style="rounded,filled", fillcolor=white, margin=0.2];
    edge [fontname="Arial", color="#555555", penwidth=1.5];

    // Hypothesis Legend
    legend [shape=rect, style=filled, fillcolor="#E6EAF4", label="HYPOTHESIS LEGEND\n\nH1 Suppressive\nH2 Feedforward\nH3 Ubiquity\nLO Local Context\nGO Global Context", pos="10,5!"];

    // The Cycle
    subgraph cluster_cycle {
        label="";
        color=none;
        node [shape=circle, fixedsize=true, width=1.5, fillcolor="#F4F6F9", color="#4A5568", penwidth=2];
        step1 [label="1\nDefine HPC Pillars\n& Contexts"];
        step2 [label="2\nSet Rules\n& Metrics"];
        step3 [label="3\nIngest &\nParse PDF"];
        step4 [label="4\nGenerate\nPrompt"];

        // Execution constraints inside the cycle area
        constraints [shape=rect, style="rounded,filled", fillcolor="#EAF8F0", color="#38A169", label="Execution Constraints\n\n• Same study context.\n• Same schema.\n• Allow abstention."];
        step1 -> step2 -> step3 -> step4 -> step1 [color="#8898AA", style=dashed, penwidth=2];
    }

    // Pipeline / Evaluation Module
    subgraph cluster_eval {
        label="PIPELINE: EVALUATION MODULE";
        style="rounded,filled";
        fillcolor="#F0F2F5";
        color="#CBD5E0";
        penwidth=2;
        margin=20;
        node [shape=box, style="rounded,filled", fillcolor=white, color="#4A5568", penwidth=1.5];
        step5 [label="5\nReasoning\n(LLM Orchestration)"];
        step6 [label="6\nVerify Outputs\n(Evaluations)"];
        step5 -> step6;
    }

    // Final Output
    step7 [shape=note, style="filled", fillcolor="#E2E8F0", color="#4A5568", penwidth=1.5, label="7\nResults Table"];

    // Connect Cycle to Pipeline to Results
    step4 -> step5 [color="#8898AA", penwidth=2];
    step6 -> step7 [color="#8898AA", penwidth=2];
}
